@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<section class="auth-panel brand-panel" data-reveal>
    <p class="eyebrow">Password reset</p>
    <h1>Reset access</h1>
    <p class="muted">For this hackathon-style MVP, password reset works by matching login ID and email, then setting a new password directly.</p>
</section>

<section class="auth-panel form-panel" data-reveal>
    <div class="section-head compact">
        <div>
            <p class="eyebrow">Recovery</p>
            <h2>Reset password</h2>
        </div>
    </div>

    <form method="post" asp-action="ForgotPassword" class="stack">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field-grid two">
            <label class="field">
                <span>Login ID</span>
                <input asp-for="LoginId" />
                <span asp-validation-for="LoginId" class="field-error"></span>
            </label>
            <label class="field">
                <span>Email Address</span>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </label>
        </div>

        <div class="field-grid two">
            <label class="field">
                <span>New Password</span>
                <input asp-for="NewPassword" />
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </label>
            <label class="field">
                <span>Confirm New Password</span>
                <input asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </label>
        </div>

        <button type="submit" class="button button-primary">Reset Password</button>
    </form>

    <div class="auth-links">
        <a asp-action="Login">Back to sign in</a>
    </div>
</section>
